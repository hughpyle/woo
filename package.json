{
  "name": "woo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "catalog:index": "node scripts/generate-bundled-catalog-index.mjs",
    "predev": "npm run catalog:index",
    "dev": "tsx src/server/dev-server.ts",
    "dump:json": "tsx src/server/dump-json.ts",
    "pretest": "npm run catalog:index",
    "test": "vitest run tests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pretypecheck": "npm run catalog:index",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "prebuild": "npm run catalog:index",
    "build": "vite build",
    "deploy": "scripts/deploy.sh"
  },
  "dependencies": {
    "vite": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
